// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Define an enum for task status
enum TaskStatus {
  UPCOMING
  IN_PROGRESS
  COMPLETED
}

// Define an enum for task priority
enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}

model ExampleTask {
  id             String     @id @default(uuid())
  name           String
  assignedToName String?
  assignedToAvatar String?
  dueDate        DateTime?
  priority       TaskPriority @default(MEDIUM)
  status         TaskStatus @default(UPCOMING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ParkingZone {
  id   String       @id @default(uuid())
  name String       @unique
  bays ParkingBay[]
}

enum BayStatus {
  AVAILABLE
  OCCUPIED
}

model ParkingBay {
  id          String      @id @default(uuid())
  bayNumber   Int
  status      BayStatus   @default(AVAILABLE)
  driverName  String?
  vehicleReg  String?
  zone        ParkingZone @relation(fields: [zoneId], references: [id])
  zoneId      String

  @@unique([zoneId, bayNumber])
}

model MonthlyAnalytics {
  id              Int @id @default(autoincrement())
  month           Int // 1 for January, 12 for December
  year            Int
  sessionDuration Int // Average session duration in minutes
  pageViews       Int // Total page views for the month
  totalVisits     Int // Total visits for the month

  @@unique([month, year]) // Ensure only one entry per month/year combination
}

model MelbourneSensor {
  id             String    @id @default(uuid())
  kerbsideId     Int       @unique
  zoneNumber     Int
  lat            Float
  lon            Float
  status         String    // "Present" | "Unoccupied"
  occupancySince DateTime? // set when status transitions to Present
  lastUpdated    DateTime
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
} 