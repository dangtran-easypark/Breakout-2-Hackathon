{
  "name": "ai-training",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "main": "index.js",
  "scripts": {
    "dev": "mkdir -p logs && concurrently --hide 0,1 --names backend,frontend,banner \"npm:dev --workspace=backend > logs/backend.log 2>&1\" \"npm:dev --workspace=frontend > logs/frontend.log 2>&1\" \"node scripts/dev-banner.mjs\"",
    "dev:verbose": "concurrently --names backend,frontend \"npm:dev --workspace=backend\" \"npm:dev --workspace=frontend\"",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write .",
    "test": "npm run test --workspaces --if-present",
    "test:backend": "npm test --workspace=backend",
    "test:frontend": "npm test --workspace=frontend",
    "test:coverage": "npm run test:coverage --workspaces --if-present"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robelkin/ai-training.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/robelkin/ai-training/issues"
  },
  "homepage": "https://github.com/robelkin/ai-training#readme",
  "description": "",
  "devDependencies": {
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.2.6",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "concurrently": "^9.1.2",
    "express-validator": "^7.2.1"
  }
}
